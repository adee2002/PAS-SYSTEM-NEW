@{
    ViewData["Title"] = "Manage Expertise Areas";
    var researchAreas = ViewBag.ResearchAreas as List<ProjectApprovalSystem.Models.ResearchArea>;
    var myExpertiseIds = ViewBag.MyExpertiseIds as List<int>;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">Manage Your Expertise Areas</h3>
                </div>
                <div class="card-body">
                    <p class="text-muted">
                        Select the research areas that match your expertise.
                        You will only see project proposals in these areas.
                    </p>

                    <form asp-action="UpdateExpertise" method="post">
                        <div class="row">
                            @if (researchAreas != null)
                            {
                                foreach (var area in researchAreas)
                                {
                                    var isChecked = myExpertiseIds != null && myExpertiseIds.Contains(area.Id);
                                    <div class="col-md-6 mb-2">
                                        <div class="form-check">
                                            <input type="checkbox"
                                                   name="selectedAreaIds"
                                                   value="@area.Id"
                                                   class="form-check-input"
                                                   id="area_@area.Id"
                                                   @(isChecked ? "checked" : "") />
                                            <label class="form-check-label" for="area_@area.Id">
                                                <strong>@area.Name</strong>
                                                @if (!string.IsNullOrEmpty(area.Description))
                                                {
                                                    <br />
                                                    <small class="text-muted">@area.Description</small>
                                                }
                                            </label>
                                        </div>
                                    </div>
                                }
                            }
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary">Save Expertise Areas</button>
                            <a asp-action="Dashboard" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-body bg-light">
                    <h6 class="card-title">💡 Why select expertise areas?</h6>
                    <p class="card-text small">
                        By selecting your expertise areas, the system will only show you project proposals
                        that match your interests. This ensures you only review relevant projects and
                        helps maintain the blind matching integrity.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>